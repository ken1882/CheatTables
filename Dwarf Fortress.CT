              <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
local ptr = getAddress("attributesPtr")
for i = 1, 10 do
  local addr = readPointer(ptr)
  if addr and addr ~= 0 then
    local max = readInteger(addr + 0x04)
    writeInteger(addr, max)
  end
  ptr = ptr + 0x08
end
{$asm}
