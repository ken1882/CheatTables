    <CheatEntry>
      <ID>461</ID>
      <Description>"Custom Free Crafts (Adamantine + Feather Wood)"</Description>
      <LastState/>
      <Color>0000FF</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]
aobscanmodule(crafts,$process,CC 48 85 D2 74 ?? 48 89 ?? ?? ?? ?? 48 83 ?? ?? F7)
alloc(newmem,$1000,crafts)

label(craftsBkp)
label(rock)
label(wood)
label(hack)
label(exit)
label(return)

newmem:
  test rdx,rdx
  reassemble(crafts+04)
  cmp word ptr [rdx+B0],#0
  je rock
  cmp word ptr [rdx+B0],#-1
  je rock
  cmp word ptr [rdx+B0],#420
  je wood
  jmp exit
rock:
  cmp [rdx+B4],#25  // adamantine ingot
  je hack
  cmp [rdx+B4],#8   // steel ingot
  je hack
  cmp [rdx+B4],#242 // adamantine ore
  je hack
  cmp [rdx+B4],#222 // chromite
  je hack
  jmp exit
wood:
  cmp [rdx+B4],#213 // feather wood
  je hack
  jmp exit
hack:
  xor rdx,rdx
  jmp newmem
exit:
  jmp return
craftsBkp:
  readmem(crafts+01,5)

crafts+01:
  jmp newmem
return:
registersymbol(crafts)
registersymbol(craftsBkp)

[DISABLE]
crafts+01:
  db 48 85 D2 74 65
unregistersymbol(crafts)
unregistersymbol(craftsBkp)
dealloc(newmem)

