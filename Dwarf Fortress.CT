    <CheatEntry>
      <ID>215</ID>
      <Description>"Rock Quern Creates Adamantine Instead"</Description>
      <Options moHideChildren="1"/>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]
aobscanmodule(createQuern,$process,E9 ?? ?? ?? ?? ?? 50 00 00 00 E9 ?? ?? ?? ?? ?? ?? ?? 00 00 E9)
alloc(newmem,$1000,createQuern)

label(createQuernMult)
label(return)

newmem:
createQuernMult:
  mov edi,#100
  mov [rsp+70],edi
  //stack offset below is likely to change with patches
  //follow jump and examine what populates r9 before the call
  mov [rbp-70],#242 // Raw Adamantine
  mov ebx,00000004 // Create Boulder
  jmp return

createQuern+05:
  jmp newmem
return:
registersymbol(createQuern)
registersymbol(createQuernMult)

[DISABLE]
createQuern+05:
  db BB 50 00 00 00
unregistersymbol(createQuern)
unregistersymbol(createQuernMult)
