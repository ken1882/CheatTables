                  <LastState/>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript Async="1">[ENABLE]
{$lua}
local value = getAddress("skillIndex")
if value &gt; 1 then
  registerSymbol("skillIndex", value - 1, false)
end
local memrec = getAddressList().getMemoryRecordByID(278)
if memrec then
  memrec.reinterpret()
end
{$asm}
assert(false)
[DISABLE]

