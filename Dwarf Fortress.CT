            <CheatEntry>
              <ID>960</ID>
              <Description>"Maximize All"</Description>
              <LastState/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
local ptr = getAddress("traitsPtr")
for i = 1, 20 do
  local addr = readPointer(ptr)
  if addr and addr ~= 0 then
    local max = readInteger(addr + 0x04)
    writeInteger(addr, max)
  end
  ptr = ptr + 0x08
end
{$asm}
[DISABLE]
</AssemblerScript>
