    <CheatEntry>
      <ID>852</ID>
      <Description>"Unlimited Ammo"</Description>
      <LastState/>
      <Color>0000FF</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]
{$lua}
if syntaxcheck then return end
local memscan = createMemScan()
local found = createFoundList(memscan)
local bytes = "EB ?? ?? 8B ?? ?? 33 ?? ?? 8D ?? 01 FF"
local start = getAddress(process)
local stop = start + getModuleSize(process)
memscan.firstScan(
  soExactValue, vtByteArray, rtRounded,
  bytes, nil, start, stop, "+X-C-W",
  fsmNotAligned, "1", true, false, false, false)
memscan.waitTillDone()
found.initialize()
local addr = found.getAddress(1)
registerSymbol("ammo", addr, true)
found.deinitialize()
found.destroy()
memscan.destroy()
memscan = nil
return "define(ammo,"..addr..")"
{$asm}
//aobscanmodule(ammo,$process,EB ?? ?? 8B ?? ?? 33 ?? ?? 8D ?? 01 FF)
ammo+0B:
  db 00
registersymbol(ammo)

[DISABLE]
ammo+0B:
  db 01
unregistersymbol(ammo)

