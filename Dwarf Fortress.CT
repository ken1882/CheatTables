            <CheatEntry>
              <ID>1098</ID>
              <Description>"Send Announcement"</Description>
              <LastState/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript Async="1">[ENABLE]
{$lua}
if syntaxcheck then return end
local memscan = createMemScan()
local found = createFoundList(memscan)
local bytes = "4C 8D ?? ?? 48 8D ?? ?? ?? ?? ?? 48 8D 0D ?? ?? ?? ?? E8 ?? ?? ?? ?? 48 8B 05"
local start = getAddress(process)
local stop = start + getModuleSize(process)
memscan.firstScan(
  soExactValue, vtByteArray, rtRounded,
  bytes, nil, start, stop, "+X-C-W",
  fsmNotAligned, "1", true, false, false, false)
memscan.waitTillDone()
found.initialize()
local addr = found.getAddress(0)
addr = tonumber(addr, 16)
addr = readInteger(addr + 0x13, true) + addr + 0x17
registerSymbol("SendAnnouncement", addr, true)
found.deinitialize()
found.destroy()
memscan.destroy()
memscan = nil
{$asm}

[DISABLE]
unregistersymbol(SendAnnouncement)

