        <CheatEntry>
          <ID>170</ID>
          <Description>"Create Item Function"</Description>
          <Options moHideChildren="1"/>
          <LastState/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript Async="1">{
RCX == Item Type (0=Bar; 2=Block; 8=Bed)
RDX == Variant (-1=None; 2=Left Hand)
R8 == Material Type (0=Rock; 420=Wood)
R9 == Material ID
}

{ Item Types
0:Bar
1:Small Gem
2:Block
3:Rough Gem
4:Boulder
5:Wood
6:Door
7:Floodgate
8:Bed
9:Chair
10:Chain
11:Flask
12:Mug
13:Ebal (Instrument)
14:Puzzlebox
15:Window
16:Cage
17:Barrel
18:Bucket
19:Animal Trap
20:Table
21:Coffin
22:Statue
24:Weapon
25:Armor
26:Shoes
27:Shield
28:Helm
29:Gloves
30:Chest/Coffer
31:Bag
32:Bin
33:Armor Stand
34:Weapon Rack
35:Cabinet
36:Figurine
37:Amulet
38:Scepter
39:Bolt
40:Crown
41:Ring
42:Earring
43:Bracelet
44:Large Gem
45:Anvil
57:Thread
58:Cloth
59:Totem
60:Pants
61:Backpack
62:Quiver
63:Catapult Parts
64:Ballista Parts
65:Ballista Arrows
66:Ballista Arrowhead
67:Mechanism
68:Large Serrated Disc
71:Cheese
77:Pipe
78:Hatch Cover
79:Grate
80:Quern
81:Millstone
82:Splint
83:Crutch
84:Traction Bench
87:Slab
}

[ENABLE]
aobscanmodule(createItem,$process,41 8B F1 45 0F B7 F8 44)
alloc(newmem,$1000,createItem)

label(createItemFunc)
label(createItemType)
label(code)
label(return)

newmem:
  cmp r8d,#420 // if material is wood
  jne code
  cmp ecx,#2   // if creating a block
  jne code
createItemType:
  mov ecx,#2
code:
  lea ecx,[ecx]
  mov esi,r9d
  movzx r15d,r8w
  jmp return

createItem:
  jmp newmem
  nop 2
return:

createItem-1F:
createItemFunc:

registersymbol(createItem)
registersymbol(createItemFunc)
registersymbol(createItemType)

[DISABLE]
createItem:
  db 41 8B F1 45 0F B7 F8
unregistersymbol(createItem)
unregistersymbol(createItemFunc)
unregistersymbol(createItemType)
dealloc(newmem)

