aobscanmodule(traits,$process,?? 6B ?? ?? ?? 6B ?? ?? 46 8B ?? ?? ?? ?? 00 00 46 2B ?? ?? ?? ?? 00 00 ?? 8B)
alloc(newmem,$1000,traits)

label(traitsBkp)
label(traitsPtr)
label(return)

newmem:
  cmp rsi,#20
  jg @f
  db 4E 8D
  readmem(traits+0A,6)
  push rcx
  mov rcx,traitsPtr
  mov [rcx+rsi*8],r8
  pop rcx
traitsBkp:
  readmem(traits+08,8)
  jmp return

align 10
traitsPtr:
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0
  dq 0

traits+08:
  jmp newmem
  nop 3
return:
registersymbol(traits)
registersymbol(traitsBkp)
registersymbol(traitsPtr)

[DISABLE]
traits+08:
  db 46 8B 84 08 AC 00 00 00
unregistersymbol(traits)
unregistersymbol(traitsBkp)
unregistersymbol(traitsPtr)
dealloc(newmem)

