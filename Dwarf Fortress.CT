                      <ID>902</ID>
                      <Description>"Click to Cycle Through Each"</Description>
                      <LastState/>
                      <VariableType>Auto Assembler Script</VariableType>
                      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local current = memrec.CurrentAddress
memrec.Address = "+0"
local vector = memrec.CurrentAddress
local first = readPointer(vector)
local last = readPointer(vector + 0x08) - 0x08
--printf("First: %X", first)
--printf("Last: %X", last)
--printf("Current: %X", current)
if not current or current &lt; first or current &gt;= last then
  memrec.Address = first
else
  memrec.Address = current + 0x08
end
assert(false, "Script Worked - Ignore This Error")
{$asm}
[DISABLE]
</AssemblerScript>
