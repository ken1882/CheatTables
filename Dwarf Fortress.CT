      <AssemblerScript Async="1">[ENABLE]
aobscanmodule(building,$process,89 ?? ?? ?? 00 00 48 8B ?? 48 8B ?? FF 90 ?? ?? ?? ?? 83 F8)
alloc(newmem,$1000,building)

label(buildingBkp)
label(buildingPtr)
label(return)

newmem:
  readmem(building+09,3)
  mov rax,buildingPtr
  mov [rax],rcx
  readmem(building+06,3)
  jmp return
buildingBkp:
  readmem(building+06,6)
  jmp return

align 10
buildingPtr:
  dq 0

building+06:
  jmp newmem
  nop
return:
registersymbol(building)
registersymbol(buildingBkp)
registersymbol(buildingPtr)

[DISABLE]
building+06:
  readmem(buildingBkp,6)
unregistersymbol(building)
unregistersymbol(buildingBkp)
unregistersymbol(buildingPtr)
dealloc(newmem)

