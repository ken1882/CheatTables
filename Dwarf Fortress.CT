    <CheatEntry>
      <ID>190</ID>
      <Description>"Wood Blocks Create Logs Instead"</Description>
      <Options moHideChildren="1"/>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]
aobscanmodule(createWood,$process,89 ?? 24 ?? C6 ?? ?? 00 C6 ?? 24 ?? 00)
alloc(newmem,$1000,createWood)

label(createWoodBkp)
label(createWoodMult)
label(code)
label(return)

newmem:
createWoodMult:
  mov edi,#100
  db 48 83 C4 14 //add rsp,14
  db 81 7C 24 // cmp [rsp+XX],#420
  readmem(createWood+03,1)
  dd #420
  jne code
@@:
  mov ebx,00000005 // create log
  db 48 83 EC 14 //sub rsp,14
  jmp createWoodBkp
code:
  mov ebx,00000002 // create block
  db 48 83 EC 14 //sub rsp,14
  jmp createWoodBkp

createWoodBkp:
  readmem(createWood,8)
  jmp return

createWood:
  jmp newmem
  nop 3
return:
registersymbol(createWood)
registersymbol(createWoodMult)
registersymbol(createWoodBkp)

[DISABLE]
createWood:
  readmem(createWoodBkp,8)
unregistersymbol(createWood)
unregistersymbol(createWoodMult)
unregistersymbol(createWoodBkp)
dealloc(newmem)

