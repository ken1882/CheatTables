        <CheatEntry>
          <ID>1180</ID>
          <Description>"replaceCraft"</Description>
          <LastState/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript Async="1">[ENABLE]
{
RCX == Item Type (0=Bar; 2=Block; 8=Bed)
RDX == Variant (-1=None; 2=Left Hand)
R8 == Material Type (0=Rock; 420=Wood)
R9 == Material ID
}
{ RCX == Item Type, RDX == Variant
24 = Weapon
  0:Whip
  1:Battle Axe
  2:War Hammer
  3:Short Sword
  4:Spear
  5:Mace
  6:Crossbow
  7:Pick
  8:Bow
  9:Blowgun
  10:Pike
  11:Halberd
  12:Two-Handed Sword
  13:Long Sword
  14:Maul
  15:Great Axe
  16:Dagger
  17:Scourge
  18:Flail
  19:Morningstart
  20:Scimitar
  21:Training Axe
  22:Training Sword
  23:Training Spear
  24:Thin Spear
  25:Jagged Mace
  26:Thin Blade
  27:Thin War Hammer
  28:Thin Blowgun
25 = Armor
26 = Boots
27 = Shield
28 = Helm
29 = Gloves
39 = Bolts
60 = Pants
}
aobscanmodule(replaceCraft,$process,0F B7 ?? ?? ?? ?? ?? 0F B7 ?? E8 ?? ?? ?? ?? ?? 8B ?? 48 8B 00)
alloc(newmem,$1000,replaceCraft)

label(value)
label(isWood)
label(isWeapon)
label(isShield)
label(setSteel)
label(setSilver)
label(setAdamantine)
label(exit)
label(replaceCraftBkp)
label(replaceCraftBkp2)
label(return)
label(funcExit)
label(funcReturn)

newmem:
replaceCraftBkp:
  readmem(replaceCraft,10)
  cmp r8d,#420
  je isWood
  jmp exit
isWood:
  cmp ecx,#24 // weapon
  je isWeapon
  cmp ecx,#27 // shield
  je isShield
  cmp ecx,#39 // ammo
  je setSteel
  jmp exit
isWeapon:
  cmp edx,#21
  jl @f
  cmp edx,#23
  jg @f
  sub edx,#19
  cmp edx,#2
  je setSilver
  //mov rdx,value
  //inc [rdx]
  //mov edx,[rdx]
@@:
  jmp setSteel
isShield:
  jmp setAdamantine
setSteel:
  xor r8,r8
  mov r9d,#8
  jmp exit
setSilver:
  xor r8,r8
  mov r9d,#2
  jmp exit
setAdamantine:
  xor r8,r8
  mov r9d,#25
  jmp exit
exit:
  jmp return

funcExit:
  or [rax+10],4000
replaceCraftBkp2:
  readmem(replaceCraft+0F,6)
  jmp funcReturn

align 10
value:
  dd #-1

replaceCraft:
  jmp newmem
  nop 5
return:

replaceCraft+0F:
  jmp funcExit
  nop
funcReturn:

registersymbol(replaceCraft)
registersymbol(replaceCraftBkp)
registersymbol(replaceCraftBkp2)

[DISABLE]
replaceCraft:
  readmem(replaceCraftBkp,10)
replaceCraft+0F:
  readmem(replaceCraftBkp2,6)
unregistersymbol(replaceCraft)
unregistersymbol(replaceCraftBkp)
unregistersymbol(replaceCraftBkp2)
dealloc(newmem)

