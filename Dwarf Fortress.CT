    <CheatEntry>
      <ID>157</ID>
      <Description>"Item Tooltip Pointer"</Description>
      <Options moHideChildren="1"/>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]
//aobscanmodule(itemTooltip,$process,48 89 4C 24 ?? 45 ?? ?? 75 ?? 48 8D)
aobscanmodule(itemTooltip,$process,?? 8B ?? 48 89 ?? ?? ?? 84 ?? 75 ?? 48 8D)
alloc(newmem,$1000,itemTooltip)

label(itemTooltipBkp)
label(itemTooltipPtr)
label(return)

newmem:
  //lea rcx,[rcx]
  push rax
  mov rax,itemTooltipPtr
  mov [rax],rcx
  pop rax
itemTooltipBkp:
  //readmem(itemTooltip,5)
