      <CheatEntries>
        <CheatEntry>
          <ID>894</ID>
          <Description>"Open the Personality &gt; Traits Panel (5000 is best)"</Description>
          <Options moHideChildren="1"/>
          <LastState Value="" RealAddress="00000000"/>
          <ShowAsSigned>0</ShowAsSigned>
          <GroupHeader>1</GroupHeader>
