          <Description>"Vacuum Items on Selection"</Description>
          <LastState/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript Async="1">[ENABLE]
aobscanmodule(vacDest,$process,0F B7 46 ?? 66 41 ?? ?? 0F B7)
alloc(newmem,$1000,vacDest)

label(vacDestBkp)
label(vacDestSave)
label(return)

newmem:
  push rcx
  mov rax,vacDestSave
  movzx ecx,word ptr [rsi+B0]
  mov [rax+00],ecx
  mov ecx,[rsi+B4]
  mov [rax+04],ecx
  mov rcx,[rsi+08]
  mov [rax+08],rcx
  pop rcx
vacDestBkp:
  readmem(vacDest,8)
  jmp return

align 10
vacDestSave:
  dq 0
  dq 0

vacDest:
  jmp newmem
  nop 3
return:
registersymbol(vacDest)
registersymbol(vacDestBkp)

aobscanmodule(vacAll,$process,F6 ?? ?? 01 0F 84 ?? ?? ?? ?? 44 0F B7 ?? ?? 48 8D)
alloc(newmem2,$1000,vacAll)

label(vacAllBkp)
label(return2)

newmem2:
  mov r9,vacDestSave
  movzx esi,word ptr [r9+00]
  cmp [rbx+B0],si
  jne @f
  mov esi,[r9+04]
  cmp [rbx+B4],esi
  jne @f
  mov esi,[r9+08]
  mov [rbx+08],esi
  movzx esi,word ptr [r9+0C]
  mov [rbx+0C],si
vacAllBkp:
  readmem(vacAll+0A,5)
  jmp return2

vacAll+0A:
  jmp newmem2
return2:
registersymbol(vacAll)
registersymbol(vacAllBkp)

[DISABLE]
vacDest:
  readmem(vacDestBkp,8)
unregistersymbol(vacDest)
unregistersymbol(vacDestBkp)
dealloc(newmem)

vacAll+0A:
  readmem(vacAllBkp,5)
unregistersymbol(vacAll)
unregistersymbol(vacAllBkp)
dealloc(newmem2)

