    <CheatEntry>
      <ID>983</ID>
      <Description>"Quantum Stockpiles"</Description>
      <Options moHideChildren="1"/>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]
aobscanmodule(quantumStockpile,$process,F6 ?? ?? ?? ?? 00 00 ?? 0F 85 ?? ?? ?? ?? 41 83 ?? FF)
alloc(newmem,$1000,quantumStockpile)

label(quantumStockpileBkp)
label(return)

newmem:
  lea rax,[rsi+D0]
  cmp [rax+18],#15
  jle @f
  mov rax,[rax]
  test rax,rax
  je quantumStockpileBkp
@@:
  cmp word ptr [rax],'z '
  jne @f
  jmp return+10
quantumStockpileBkp:
  readmem(quantumStockpile,8)
  jmp return

quantumStockpile:
  jmp newmem
  nop 3
return:
registersymbol(quantumStockpile)
registersymbol(quantumStockpileBkp)

aobscanmodule(quantumStockpile2,$process,A8 20 0F 85 ?? ?? ?? ?? ?? 8B ?? ?? 8B)
quantumStockpile2+02:
  db EB 04
registersymbol(quantumStockpile2)

[DISABLE]
quantumStockpile:
  readmem(quantumStockpileBkp,8)
unregistersymbol(quantumStockpile)
unregistersymbol(quantumStockpileBkp)
dealloc(newmem)

quantumStockpile2+02:
  db 0F 85
unregistersymbol(quantumStockpile2)

