    <CheatEntry>
      <ID>898</ID>
      <Description>"Unit Pointer"</Description>
      <Options moHideChildren="1"/>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
aobscanmodule(unit,$process,F3 0F ?? ?? ?? ?? 89 ?? ?? F3 0F ?? ?? ?? ?? ?? 89 ?? ?? ?? F3 0F ?? ?? ?? ?? 89 ?? ?? ?? 8B ?? ?? ?? 00 00)
alloc(newmem,$1000,unit)

label(unitSoulOff)
label(unitPtr)
label(unitBkp)
label(return)

(DWORD)[unit+20]:
unitSoulOff:

newmem:
  mov rax,unitPtr
  mov [rax],r13
unitBkp:
  readmem(unit+1D,7)
  jmp return

align 10
unitPtr:
  dq 0

unit+1D:
  jmp newmem
  nop 2
return:
registersymbol(unit)
registersymbol(unitBkp)
registersymbol(unitPtr)
registersymbol(unitSoulOff)

[DISABLE]
unit+1D:
  readmem(unitBkp,7)
unregistersymbol(unit)
unregistersymbol(unitBkp)
unregistersymbol(unitPtr)
unregistersymbol(unitSoulOff)
dealloc(newmem)

