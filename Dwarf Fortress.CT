    <CheatEntry>
      <ID>563</ID>
      <Description>"Instant Teleport to Job Site"</Description>
      <Options moHideChildren="1"/>
      <LastState/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
aobscanmodule(teleport,$process,0F 84 ?? ?? ?? ?? 66 89 ?? ?? ?? 00 00 66 89)
alloc(newmem,$1000,teleport)

label(teleportOn)
label(teleportBkp)
label(return)
label(hack)

newmem:
  cmp r14,0
  jl teleportBkp
  cmp r14,200
  jg teleportBkp
  mov rax,teleportOn
  cmp byte ptr [rax+r14],1
  je hack
  jmp teleportBkp
hack:
  mov [rcx+A8],bp
  mov [rcx+AA],si
  mov [rcx+AC],r9w
teleportBkp:
  readmem(teleport+06,7)
  jmp return

align 10
teleportOn:
  dq 0 //7
  dq 0 //15
  dq 0 //23
  dq 0 //31
  dq 0 //39
  dq 0 //47
  dq 0 //55
  dq 0 //63
  db 0 //64
  db 0 //65
  db 0 //66 DropOffJobItems
  db 0 //67 GrabJobResources
  db 0 //68
  db 0 //69
  db 0 //70
  db 0 //71
  dq 0 //79
  dq 0 //87
  dq 0 //95
  db 0 //96
  db 0 //97
  db 0 //98
  db 0 //99
  db 1 //100 SeekItemForStorage
  db 1 //101 StoreItem
  db 0 //102
  db 0 //103
  db 0 //104
  dq 0 //112
  dq 0 //120
  dq 0 //128
  dq 0 //136
  dq 0 //144
  dq 0 //152
  dq 0 //160
  dq 0 //168
  dq 0 //176
  dq 0 //184
  dq 0 //192
  dq 0 //200

teleport+06:
  jmp newmem
  nop 2
return:
registersymbol(teleport)
registersymbol(teleportBkp)
registersymbol(teleportOn)

[DISABLE]
teleport+06:
  readmem(teleportBkp,7)
unregistersymbol(teleport)
unregistersymbol(teleportBkp)
unregistersymbol(teleportOn)
