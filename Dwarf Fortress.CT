aobscanmodule(diety,$process,?? 8B ?? ?? 8B 51 08 48 8D 0D ?? ?? ?? ?? E8 ?? ?? ?? ?? 48 8B ?? 48 89)
alloc(newmem,$1000,diety)

label(dietyBkp)
label(dietyPtr)
label(return)

newmem:
  readmem(diety+00,4)
  mov rdx,[rcx]
  test rdx,rdx
  je @f
  mov rdx,[rdx]
  test rdx,rdx
  je @f
  cmp [rdx+01],#4
  jne @f
  mov edx,[rcx+08]
  mov rdx,dietyPtr
  mov [rdx],rcx
@@:
  readmem(diety+04,3)
  jmp return
dietyBkp:
  readmem(diety,7)
  jmp return

align 10
dietyPtr:
  dq 0

diety:
  jmp newmem
  nop 2
return:
registersymbol(diety)
registersymbol(dietyBkp)
registersymbol(dietyPtr)

[DISABLE]
diety:
  db 4A 8B 0C 28 8B 51 08
unregistersymbol(diety)
unregistersymbol(dietyBkp)
unregistersymbol(dietyPtr)
dealloc(newmem)

