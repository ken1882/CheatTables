          <ID>966</ID>
          <Description>"Embark Max Skills When Viewed"</Description>
          <LastState Activated="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript Async="1">[ENABLE]
aobscanmodule(embarkMaxSkills,$process,83 ?? ?? ?? 00 7E ?? ?? 63 ?? ?? ?? 00 00)
alloc(newmem,$1000,embarkMaxSkills)

label(embarkMaxSkillsBkp)
label(return)

