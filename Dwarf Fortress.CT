          <ID>1350</ID>
          <Description>"Unlimited Ammo"</Description>
          <LastState/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : Dwarf Fortress.exe
  Version: 
  Date   : 2026-06-07
  Author : Compeador

  This script does blah blah blah
}

[ENABLE]

aobscanmodule(INJ_AMMO,Dwarf Fortress.exe,44 29 81 80 00 00 00) // should be unique
alloc(newmem,$1000,INJ_AMMO)

label(code)
label(return)

newmem:
  xor r8d,r8d
code:
  sub [rcx+00000080],r8d
  jmp return

INJ_AMMO:
  jmp newmem
  nop 2
return:
registersymbol(INJ_AMMO)

[DISABLE]

INJ_AMMO:
  db 44 29 81 80 00 00 00

unregistersymbol(INJ_AMMO)
dealloc(newmem)

