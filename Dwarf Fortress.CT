        <CheatEntry>
          <ID>75</ID>
          <Description>"Instant Skill Levels"</Description>
          <LastState/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript Async="1">[ENABLE]
aobscanmodule(skills,$process,?? 89 ?? ?? 41 8D ?? ?? 6B C8 ?? 44 3B)
alloc(newmem,$1000,skills)

label(skillsBkp)
label(return)

newmem:
  cmp r8d,#15
  jge @f
  cmp [r15+unit_civ_id],player_civ_id
  jne @f
  readmem(skills+04,7) // lea eax,[r8+05]
                       // imul ecx,eax,64
  mov r9d,ecx
  readmem(skills+00,4)
  jmp return+03
skillsBkp:
  readmem(skills,8)
  jmp return

skills:
  jmp newmem
  nop 3
return:
registersymbol(skills)
registersymbol(skillsBkp)

[DISABLE]
skills:
  db 45 89 4A 08 41 8D 40 05
unregistersymbol(skills)
unregistersymbol(skillsBkp)
dealloc(newmem)

