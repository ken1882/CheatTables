    <CheatEntry>
      <ID>252</ID>
      <Description>"Always Craft Flawless Quality"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">{ Game   : Going Medieval.exe
  Version:
  Date   : 2026-05-10
  Author : Compeador

  Force produced item quality to 6
}

[ENABLE]
{$lua}
if syntaxcheck then return "define(address,1)" end

local memscan = createMemScan()
local found = createFoundList(memscan)

-- Anchor from:
-- call r11
-- xor eax,eax
-- jmp +7
-- movsxd rax,[rbp-88]
-- restore registers...
--
-- The actual injection point is +05 from this signature.
local bytes = "41 FF D3 33 C0 EB 07 48 63 85 78 FF FF FF 48 8B 5D C8 48 8B 75 D0 48 8B 7D D8"

local start = 0x000000000000
local stop  = 0x7FFFFFFFFFFF

memscan.firstScan(
  soExactValue, vtByteArray, rtRounded,
  bytes, nil, start, stop, "+X-C+W",
  fsmNotAligned, "1", true, false, false, false
)

memscan.waitTillDone()
found.initialize()

local count = found.Count
assert(count &gt; 0, "Unable to find GetProductQuality array of bytes.")

local selected = nil

for i = 0, count - 1 do
  local base = getAddress(found.Address[i])

  -- Verify the exact 9 bytes we intend to overwrite:
  -- EB 07 48 63 85 78 FF FF FF
  local b = readBytes(base + 0x05, 9, true)

  if b
    and b[1] == 0xEB
    and b[2] == 0x07
    and b[3] == 0x48
    and b[4] == 0x63
    and b[5] == 0x85
    and b[6] == 0x78
    and b[7] == 0xFF
    and b[8] == 0xFF
    and b[9] == 0xFF
  then
    selected = base + 0x05
    break
  end
end

memscan.Destroy()
memscan = nil

assert(selected ~= nil, "Found signature, but no valid injection point.")

return string.format("define(address,%X)", selected)
{$asm}

define(bytes,EB 07 48 63 85 78 FF FF FF)

assert(address,bytes)

alloc(qualityBkp,9)

qualityBkp:
  readmem(address,9)

address:
  nop 2
  mov eax,6
  nop 2

registersymbol(qualityBkp)

[DISABLE]

address:
  readmem(qualityBkp,9)

unregistersymbol(qualityBkp)
dealloc(qualityBkp)

