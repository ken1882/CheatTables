    <CheatEntry>
      <ID>466</ID>
      <Description>"Production Hacks"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Game   : Going Medieval.exe
  Version:
  Date   : 2026-05-11
  Author : Compeador

  Pause dung production timer
}

[ENABLE]
{$lua}
if syntaxcheck then
  return "define(INJ_PRODUCTION_TIMER,1)"
end

local memscan = createMemScan()
local found = createFoundList(memscan)

-- Injection point:
-- 48 8B C8              mov rcx,rax
-- 83 39 00              cmp dword ptr [rcx],00
-- 0F B6 40 2D           movzx eax,byte ptr [rax+2D]
-- 85 C0                 test eax,eax
-- 0F 85 ?? ?? ?? ??     jne ...
--
-- Use longer context to avoid wrong first result.
local bytes = "48 8B C8 83 39 00 0F B6 40 2D 85 C0 0F 85 ?? ?? ?? ?? 83 3E 00 F3 0F 10 46 24"

local start = 0x000000000000
local stop  = 0x7FFFFFFFFFFF

memscan.firstScan(
  soExactValue, vtByteArray, rtRounded,
  bytes, nil, start, stop, "+X-C+W",
  fsmNotAligned, "1", true, false, false, false
)

memscan.waitTillDone()
found.initialize()

local count = found.Count
assert(count &gt; 0, "Unable to find production timer AOB.")

local selected = nil

for i = 0, count - 1 do
  local addr = getAddress(found.Address[i])

  -- Verify the exact bytes we overwrite:
  -- mov rcx,rax
  -- cmp dword ptr [rcx],00
  local b = readBytes(addr, 6, true)

  if b
    and b[1] == 0x48
    and b[2] == 0x8B
    and b[3] == 0xC8
    and b[4] == 0x83
    and b[5] == 0x39
    and b[6] == 0x00
  then
    selected = addr
    break
  end
end

memscan.Destroy()
memscan = nil
found = nil

assert(selected ~= nil, "Found production timer pattern, but no valid injection point.")

return string.format("define(INJ_PRODUCTION_TIMER,%X)", selected)
{$asm}

alloc(newmem,$1000,INJ_PRODUCTION_TIMER)

label(code)
label(return)
label(skip)

newmem:
  jmp code
  push rbx
  push rdx

  test rax,rax
  jz skip

  // rax = timer/ref object
  mov rcx,[rax+18]        // TimerJobCompleted?
  test rcx,rcx
  jz skip

  mov rdx,[rcx]
  test rdx,rdx
  jz skip

  mov rcx,[rcx+20]        // TimerJobCompleted.m_target?
  test rcx,rcx
  jz skip

  mov rdx,[rcx]
  test rdx,rdx
  jz skip

  mov rcx,[rcx+20]        // blueprint?
  test rcx,rcx
  jz skip

  mov rdx,[rcx]
  test rdx,rdx
  jz skip

  mov rcx,[rcx+20]        // productId?
  test rcx,rcx
  jz skip

  mov rdx,[rcx]
  test rdx,rdx
  jz skip

  // If productId is System.String:
  // length at +10, UTF-16 chars at +14
  cmp dword ptr [rcx+10],4
  jne skip

  mov rbx,0067006E00750064 // "dung" UTF-16 little endian
  cmp qword ptr [rcx+14],rbx
  jne skip

  // Do not destroy rax.
  // Make original:
  //   movzx eax,byte ptr [rax+2D]
  // read true.
  mov byte ptr [rax+2D],01

skip:
  pop rdx
  pop rbx

code:
  // Original overwritten code
  mov rcx,rax
  cmp dword ptr [rcx],00
  jmp return

INJ_PRODUCTION_TIMER:
  jmp newmem
  nop

return:
registersymbol(INJ_PRODUCTION_TIMER)

[DISABLE]

INJ_PRODUCTION_TIMER:
  db 48 8B C8 83 39 00

unregistersymbol(INJ_PRODUCTION_TIMER)
dealloc(newmem)

