--end

local worker = readPointer("selectionPtr")
worker = readPointer(worker + 0xE8)
local skills = readPointer(worker + 0x230)
skills = readPointer(skills + 0x10)
skills = readPointer(skills + 0x10)
local count = readInteger(skills + 0x18) - 1
for i = 1, count do
  local skill = readPointer(skills + i * 0x08 + 0x20)
  if skill and skill ~= 0 then
    local name = readPointer(skill + 0x10)
    if name and name ~= 0 then
      name = readString(name + 0x14, 256, true)
      if name and string.sub(name, 1, 10) == "skill_name" then
        writeInteger(skill + 0x2C, 5)
      end
    end
  end
end

messageDialog("success", mtInformation, mbOk)
 
{$asm}
assert(true)
[DISABLE]

</AssemblerScript>
                </CheatEntry>
                <CheatEntry>
                  <ID>149</ID>
                  <Description>"Add 10,000 Experience to Each Skill"</Description>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local choice = messageDialog("Permanently add 10,000 experience to each skill?", mtWarning, mbYes, mbNo)
if choice ~= mrYes then
  return false,"cancel"
end

local worker = readPointer("selectionPtr")
worker = readPointer(worker + 0x98)
local skills = readPointer(worker + 0x1B0)
skills = readPointer(skills + 0x10)
skills = readPointer(skills + 0x10)
local count = readInteger(skills + 0x18) - 1
for i = 1, count do
  local skill = readPointer(skills + i * 0x08 + 0x20)
  if skill and skill ~= 0 then
    local name = readPointer(skill + 0x10)
    if name and name ~= 0 then
      name = readString(name + 0x14, 256, true)
      if name and string.sub(name, 1, 10) == "skill_name" then
        local xp = readFloat(skill + 0x28)
        writeFloat(skill + 0x28, xp + 10000)
      end
    end
  end
end

messageDialog("success", mtInformation, mbOk)
 
