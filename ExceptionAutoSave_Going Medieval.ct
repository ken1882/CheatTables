        <CheatEntry>
          <ID>166</ID>
          <Description>"Unlimited z Stockpiles"</Description>
          <Options moHideChildren="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript Async="1">[ENABLE]
aobscan(resources,4C 8B ?? 48 8B ?? ?? FF 50 18 48 8B ?? ?? 48 8B ?? 48 8B)
alloc(resourcesBkp,$1000,resources)
label(return)

resourcesBkp:
  readmem(resources,7)
  push rbx
  test r12,r12
  je @f
  mov rbx,[rcx+20] // Action`1.m_target
  test rbx,rbx
  je @f
  mov rbx,[rbx+F8] // ResourcePileInstance.InstanceStockpile
  test rbx,rbx
  je @f
  mov rbx,[rbx+78] // InstanceStockpile.stockpileName
  test rbx,rbx
  je @f
  cmp [rbx+14],0020007A // z&lt;space&gt;
  jne @f
  add [r12+40],r8d
  mov ebx,[rdx+108]
  cmp ebx,#1000
  jg @f
  cmp [r12+40],ebx
  jg @f
  mov [r12+40],ebx
@@:
  pop rbx
  jmp return

resources:
  jmp resourcesBkp
  nop 2
return:
registersymbol(resources)
registersymbol(resourcesBkp)

[DISABLE]
resources:
  readmem(resourcesBkp,7)
unregistersymbol(resources)
unregistersymbol(resourcesBkp)
dealloc(resourcesBkp)

