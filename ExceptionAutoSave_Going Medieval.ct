          <AssemblerScript Async="1">[ENABLE]
aobscan(growth,F3 0F 5A C0 F3 0F 10 0D ?? ?? ?? ?? F3 0F 5A C9 66 0F 2F C8 0F 8A ?? ?? ?? ?? 0F 87 ?? ?? ?? ?? 48 8B CE 33 D2)
