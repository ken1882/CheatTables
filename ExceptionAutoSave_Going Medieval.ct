          <AssemblerScript Async="1">[ENABLE]
aobscan(setStat,41 FF ?? F3 0F 5A C0 F2 0F 5A ?? F3 0F 11 ?? ?? C7 ?? ?? 00 00 00 00)
alloc(newmem,$1000,setStat)

label(setStatBkp)
label(setStatPtr)
label(return)

newmem:
  push rcx
  mov rcx,setStatPtr
  cmp [rcx],rsi
  jne @f
  nop
@@:
  pop rcx
setStatBkp:
  readmem(setStat+0B,5)
  jmp return

align 8
setStatPtr:
  dq 0

setStat+0B:
  jmp newmem
return:
registersymbol(setStat)
registersymbol(setStatBkp)
registersymbol(setStatPtr)

