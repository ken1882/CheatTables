  cvtss2sd xmm1,xmm1
  mov rcx,[rsi+98] // blueprint
  mov edx,[rcx+9C] // harvestPhase
  test edx,edx
  jns @f
  mov edx,[rcx+A0] // cutPhase
  test edx,edx
  js code
