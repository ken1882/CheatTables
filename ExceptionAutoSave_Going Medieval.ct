  <LuaScript>--[[
local worker = readPointer("selectionPtr")
worker = readPointer(worker + 0x98)
local skills = readPointer(worker + 0x1B0)
skills = readPointer(skills + 0x10)
skills = readPointer(skills + 0x10)
local count = readInteger(skills + 0x18) - 1
for i = 1, count do
  local skill = readPointer(skills + i * 0x08 + 0x20)
  local name = readPointer(skill + 0x10)
  name = readString(name + 0x14, 256, true)
  print(name)
  if skill and skill ~= 0 then
     --writeInteger(skill + 0x2C, 2)
  end
end
--]]

--[[]
-- NSMedieval.State:WorkerInstance:get_Perks+28
local worker = readPointer("workerPtr")
local skills = readPointer(worker + 0x128)
skills = readPointer(skills + 0x10)
skills = readPointer(skills + 0x10)
local count = readInteger(skills + 0x18) - 1
for i = 1, count do
  local skill = readPointer(skills + i * 0x08 + 0x20)
  local name = readPointer(skill + 0x10)
  if name then
    name = readString(name + 0x14, 256, true)
    if string.sub(name, 1, 10) == "skill_name" then
       writeFloat(skill + 0x20, 100000)
       --writeInteger(skill + 0x24, 2)
    end
  end
end
--]]

--[[
-- Number of Perks to Generate
NSMedieval:WorkerGenerator:GetPerks+3dc - 48 8B 00              - mov rax,[rax]
NSMedieval:WorkerGenerator:GetPerks+3df - FF 50 60              - call qword ptr [rax+60]
NSMedieval:WorkerGenerator:GetPerks+3e2 - 89 85 70FFFFFF        - mov [rbp-00000090],eax

-- Get Random Perk
NSMedieval:WorkerGenerator:GetPerks+6be - 49 BB 008D4737C3010000 - mov r11,NSMedieval.Repository:PerkRepository:GetPerk
NSMedieval:WorkerGenerator:GetPerks+6c8 - 41 FF D3              - call r11
]]

--[[
local stats = 0x1D4F23C5F00
local count = readInteger(stats + 0x18)
stats = stats + 0x20
for i = 1, count do
  local stat = readPointer(stats)
  local statType = readInteger(stat + 0x28)
  local threshold = readPointer(stat + 0x20)
  local name = "Unknown"
  if readInteger(threshold + 0x18) &gt; 0 then
    threshold = readPointer(threshold + 0x20)
    name = readPointer(threshold + 0x10)
    name = readString(name + 0x14, 256, true)
  end
  printf("%02d %s", statType, name)
  stats = stats + 0x08
end
--]]
</LuaScript>
