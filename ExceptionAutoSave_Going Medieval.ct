      <Description>"Instant Passive Production"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Game   : Going Medieval.exe
  Version: 
  Date   : 2026-05-09
  Author : Compeador

  This script does blah blah blah
}

define(address,NSMedieval.State.ProductionStepPassive:OnTick+da )
define(bytes,F3 0F 11 6E 40)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,NSMedieval.State.ProductionStepPassive:OnTick+da )

label(code)
label(return)

newmem:
  push rax
  mov rax,(float)1000.0
  movd xmm5,rax
  pop rax
code:
  movss [rsi+40],xmm5
  jmp return

address:
  jmp newmem
return:

[DISABLE]

address:
  db bytes
  // movss [rsi+40],xmm5

dealloc(newmem)

